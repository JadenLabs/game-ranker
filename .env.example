# Copy to .env.local and fill in your own values.
# The app needs DATABASE_URL and BETTER_AUTH_SECRET: email/password auth always works,
# Google/Discord buttons and game search appear once their keys are present.

# Postgres connection string. Free tier at https://neon.tech works well.
# Use the pooled connection string (host contains "-pooler") for serverless deploys.
DATABASE_URL="postgresql://user:password@host-pooler.region.aws.neon.tech/neondb?sslmode=require"

# Random string, e.g. from: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
BETTER_AUTH_SECRET=""
BETTER_AUTH_URL="http://localhost:3000"

# Google OAuth: https://console.cloud.google.com
# Create OAuth client ID (Web application) with redirect URI:
#   http://localhost:3000/api/auth/callback/google
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Discord OAuth: https://discord.com/developers/applications
# OAuth2 tab, add redirect:
#   http://localhost:3000/api/auth/callback/discord
DISCORD_CLIENT_ID=""
DISCORD_CLIENT_SECRET=""

# IGDB game search: https://dev.twitch.tv/console (Twitch account with 2FA)
# Register an application, category Application Integration.
TWITCH_CLIENT_ID=""
TWITCH_CLIENT_SECRET=""
